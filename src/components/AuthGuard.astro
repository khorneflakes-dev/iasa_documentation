---
// src/components/AuthGuard.astro
// Verifica sesión de Cognito antes de mostrar contenido
---

<div
  id="auth-loading"
  style="position:fixed;inset:0;z-index:9999;background:var(--sl-color-bg,#fff);display:flex;align-items:center;justify-content:center;"
>
  <p style="font-family:system-ui,sans-serif;color:var(--sl-color-text,#333);">
    Verificando sesión...
  </p>
</div>

<script>
  import { Amplify } from 'aws-amplify';
  import { fetchAuthSession } from 'aws-amplify/auth';

  Amplify.configure({
    Auth: {
      Cognito: {
        userPoolId: 'us-east-1_z84PYBuOM',
        userPoolClientId: '7dhoflet374a7fl6jp6kmnr7n0',
      },
    },
  });

  (async () => {
    try {
      const session = await fetchAuthSession();

      if (!session.tokens?.idToken) {
        // Sin sesión válida → redirigir a login
        const base = import.meta.env.BASE_URL.replace(/\/$/, '');
        window.location.replace(base + '/login');
        return;
      }

      // Sesión válida → mostrar contenido
      document.getElementById('auth-loading')?.remove();
    } catch {
      const base = import.meta.env.BASE_URL.replace(/\/$/, '');
      window.location.replace(base + '/login');
    }
  })();
</script>
