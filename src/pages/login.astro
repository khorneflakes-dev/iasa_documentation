---
// src/pages/login.astro
import bg from '../assets/bg.avif';
import { AUTH_ENABLED } from '../config';

// Si el login está desactivado, redirigir al inicio
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
if (!AUTH_ENABLED) {
  return Astro.redirect(base + '/es/');
}
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar sesión</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        background-image: var(--bg);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #111;
      }

      .card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 12px;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 360px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
      }

      h1 {
        font-size: 1.1rem;
        font-weight: 600;
        text-align: center;
        margin-bottom: 1.75rem;
        color: #111;
      }

      .field {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        margin-bottom: 1rem;
      }

      label {
        font-size: 0.8rem;
        font-weight: 500;
        color: #555;
      }

      input {
        padding: 0.6rem 0.75rem;
        border: 1px solid #d4d4d4;
        border-radius: 6px;
        font-size: 0.9rem;
        outline: none;
        transition: border-color 0.15s;
        width: 100%;
        background: #fafafa;
      }

      input:focus {
        border-color: #888;
        background: #fff;
      }

      button[type="submit"] {
        width: 100%;
        margin-top: 0.5rem;
        padding: 0.65rem;
        background: #111;
        color: #fff;
        border: none;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.15s, opacity 0.15s;
      }

      button[type="submit"]:hover:not(:disabled) { background: #333; }
      button[type="submit"]:disabled { opacity: 0.5; cursor: not-allowed; }

      #mensaje {
        margin-top: 1rem;
        padding: 0.6rem 0.75rem;
        border-radius: 6px;
        font-size: 0.82rem;
        display: none;
        line-height: 1.4;
      }

      #mensaje.error   { background: #fff0f0; color: #b91c1c; border: 1px solid #fca5a5; }
      #mensaje.aviso   { background: #fffbeb; color: #92400e; border: 1px solid #fcd34d; }
      #mensaje.exito   { background: #f0fdf4; color: #166534; border: 1px solid #86efac; }
    </style>
  </head>
  <body style={`--bg: url('${bg.src}')`}>
    <div class="card">
      <h1>Iniciar sesión</h1>
      <form id="loginForm" novalidate>
        <div class="field">
          <label for="username">Usuario</label>
          <input type="text" id="username" name="username" autocomplete="username" required />
        </div>
        <div class="field">
          <label for="password">Contraseña</label>
          <input type="password" id="password" name="password" autocomplete="current-password" required />
        </div>
        <button type="submit" id="submitBtn">Entrar</button>
      </form>
      <p id="mensaje" role="alert" aria-live="polite"></p>
    </div>

    <script>
      import { Amplify } from 'aws-amplify';
      import { signIn } from 'aws-amplify/auth';

      Amplify.configure({
        Auth: {
          Cognito: {
            userPoolId: 'us-east-1_z84PYBuOM',
            userPoolClientId: '7dhoflet374a7fl6jp6kmnr7n0',
          },
        },
      });

      const ERRORES: Record<string, string> = {
        NotAuthorizedException:        'Usuario o contraseña incorrectos.',
        UserNotFoundException:          'No existe una cuenta con ese usuario.',
        UserNotConfirmedException:      'La cuenta aún no ha sido confirmada. Revisa tu correo.',
        PasswordResetRequiredException: 'Debes restablecer tu contraseña antes de continuar.',
        TooManyRequestsException:       'Demasiados intentos. Espera unos minutos e inténtalo de nuevo.',
        LimitExceededException:         'Se superó el límite de intentos. Inténtalo más tarde.',
        NetworkError:                   'Sin conexión a internet. Verifica tu red e intenta de nuevo.',
        UserLambdaValidationException:  'Error de validación en el servidor. Contacta al administrador.',
        InvalidParameterException:      'El usuario o la contraseña tienen un formato inválido.',
      };

      const form       = document.getElementById('loginForm')  as HTMLFormElement;
      const submitBtn  = document.getElementById('submitBtn')  as HTMLButtonElement;
      const mensaje    = document.getElementById('mensaje')!;

      function mostrar(tipo: 'error' | 'aviso' | 'exito', texto: string) {
        mensaje.className = tipo;
        mensaje.textContent = texto;
        mensaje.style.display = 'block';
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const username = (document.getElementById('username') as HTMLInputElement).value.trim();
        const password = (document.getElementById('password') as HTMLInputElement).value;

        if (!username || !password) {
          mostrar('aviso', 'Por favor, completa todos los campos.');
          return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Verificando...';
        mensaje.style.display = 'none';

        try {
          const { isSignedIn, nextStep } = await signIn({ username, password });

          if (isSignedIn) {
            mostrar('exito', 'Sesión iniciada. Redirigiendo...');
            const base = import.meta.env.BASE_URL.replace(/\/$/, '');
            window.location.replace(base + '/es/');
          } else if (nextStep.signInStep === 'CONFIRM_SIGN_IN_WITH_NEW_PASSWORD_REQUIRED') {
            mostrar('aviso', 'Debes establecer una nueva contraseña antes de continuar.');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Entrar';
          }
        } catch (err: any) {
          const codigo: string = err.name ?? err.code ?? '';
          const mensaje_es = ERRORES[codigo] ?? 'Ocurrió un error inesperado. Inténtalo de nuevo.';
          mostrar('error', mensaje_es);
          submitBtn.disabled = false;
          submitBtn.textContent = 'Entrar';
        }
      });
    </script>
  </body>
</html>